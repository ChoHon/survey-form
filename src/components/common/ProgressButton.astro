---
const { href, type, label } = Astro.props;
---

<a href={href} class={`progress-button-${type}`}>
  {label}
</a>

<style>
  @import "tailwindcss";

  .progress-button-prev {
    width: 100px;
    text-align: center;

    @apply rounded-l-md bg-blue-600 px-3.5 py-2.5 text-lg font-semibold text-white shadow-xs outline-1 outline-white hover:bg-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600;
  }

  .progress-button-next {
    @apply w-[100px] rounded-r-md bg-blue-600 px-3.5 py-2.5 text-center text-lg font-semibold text-white shadow-xs outline-1 outline-white hover:bg-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600;
  }

  .progress-button-single {
    @apply w-[150px] rounded-md bg-blue-600 px-3.5 py-2.5 text-center text-lg font-semibold text-white shadow-xs hover:bg-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600;
  }

  .progress-button-summit {
    @apply w-[100px] rounded-r-md bg-green-600 px-3.5 py-2.5 text-center text-lg font-semibold text-white shadow-xs outline-1 outline-white hover:bg-green-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600;
  }
</style>
